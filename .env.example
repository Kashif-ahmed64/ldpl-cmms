# =============================================================================
# LDPL CMMS — Server Configuration (.env on the SERVER PC only)
# Copy to .env and edit before first run: cp .env.example .env
# =============================================================================

# PostgreSQL — create database ldpl_cmms_db before running db:setup
DATABASE_URL="postgresql://cmms_user:YOUR_PASSWORD@localhost:5432/ldpl_cmms_db?schema=public"

# API Server — bind all interfaces so workstations on LAN can connect
HOST=0.0.0.0
PORT=3001
NODE_ENV=production

# JWT — REQUIRED: generate long random strings for production
# Example: openssl rand -base64 48
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_LONG_RANDOM_SECRET
JWT_REFRESH_EXPIRES_IN=7d

# Legacy CORS hint (desktop clients use Electron store for API URL)
CLIENT_URL=http://localhost:5173

# Vite dev fallback only (not used by packaged desktop app)
VITE_API_URL=http://localhost:3001

# File uploads (created automatically if missing)
UPLOAD_DIR=./uploads

# Nightly database backups (recommended for production)
BACKUP_DIR=./backups
BACKUP_ENCRYPTION_KEY=
BACKUP_RETENTION_DAYS=30
